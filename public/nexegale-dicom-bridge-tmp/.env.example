# ── Orthanc DICOM Server ─────────────────────────────────────────
ORTHANC_URL=http://localhost:8042
ORTHANC_USER=orthanc
ORTHANC_PASS=orthanc

# ── NexEgale / 1Rad API ──────────────────────────────────────────
ONERAD_API_URL=https://1radapi-bch4ere7a6cmgkap.centralindia-01.azurewebsites.net/api/v1
ONERAD_EMAIL=admin@yourclinic.com
ONERAD_PASSWORD=yourpassword

# ── Bridge Behaviour ─────────────────────────────────────────────
# How often to poll Orthanc for new studies (seconds)
POLL_INTERVAL_SECONDS=30

# Minimum match confidence to auto-upload (0.0 - 1.0)
# Score is weighted: name(50%) + date(35%) + modality(15%)
MATCH_CONFIDENCE_THRESHOLD=0.6

# Where to store the SQLite database and logs
DATA_DIR=C:\ProgramData\NexEgale\bridge

# ── Logging ──────────────────────────────────────────────────────
# info | debug | warn | error
LOG_LEVEL=info
